<?xml version="1.0" encoding="UTF-8"?>
<!--
  mod08/build.xml — eighth link in the 10-module deep chain.
  Hosts: commons-codec-1.11.jar in lib/.
-->
<project name="mod08" default="resolve" basedir="."
         xmlns:ivy="antlib:org.apache.ivy.ant">

    <property name="ivy.settings.file" value="${basedir}/../ivysettings.xml"/>

    <taskdef resource="org/apache/ivy/ant/antlib.xml"
             uri="antlib:org.apache.ivy.ant"
             classpath="${ivy.jar.path}"/>

    <target name="resolve" description="Resolve mod08 dependencies">
        <ivy:settings file="${ivy.settings.file}"/>
        <ivy:resolve file="${basedir}/ivy.xml"
                     conf="compile"
                     failonerror="false"
                     log="download-only"/>
        <ivy:cachepath pathid="compile.classpath"
                       conf="compile"
                       failonerror="false"/>
        <ivy:retrieve pattern="${basedir}/lib/[artifact]-[revision].[ext]"
                      conf="compile"
                      overwriteMode="different"/>
    </target>

</project>
