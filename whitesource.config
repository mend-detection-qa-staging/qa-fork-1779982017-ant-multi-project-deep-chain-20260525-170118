# Unified Agent configuration for Ant+Ivy resolution.
# Mode 1 (Ivy resolution via ivy.xml + ivysettings.xml) fires when both flags below are true.
# Without these flags the UA Ant resolver falls back to Mode 3 (binary file path scan).
# See whitesource/unified-agent .claude/knowledge/resolvers/java-jvm.md § 3 Ant Resolver.

ant.resolveDependencies=true
ant.ivyResolveDependencies=true

# Resolve the compile configuration across all sub-projects.
# Empty list = no configurations ignored.
ant.ivyIgnoredConfigurations=

# Do not exclude source files from fingerprinting; probe ships no Java sources.
ant.ignoreSourceFiles=false
